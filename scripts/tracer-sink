#!/usr/bin/env python3
"""
tracer-sink — детерминированный оркестратор трейса EDT Debug Tracer.

Контракт: docs/BRD-cli-sink.md, docs/SRS-cli-sink.md

Алгоритм:
  1. Разобрать аргументы
  2. --help / --version
  3. Прочитать JSON из аргумента или stdin
  4. Распарсить JSON  → exit 2 при ошибке
  5. Валидировать поля  → exit 2 при нарушении
  6. POST /sink/run     → exit 1 при ошибке сети
  7. Маппинг ответа  → exit 0 / 3 / 4
Бизнес-логика трейса — в TracerSink.java, не здесь.
"""
import argparse
import json
import sys
import urllib.error
import urllib.request

VERSION = "1.0.0"

EXIT_SUCCESS        = 0
EXIT_NETWORK_ERROR  = 1
EXIT_CONTRACT_ERROR = 2
EXIT_RUNTIME_ERROR  = 3
EXIT_INTERNAL_ERROR = 4

VALID_STEP_TYPES = {"into", "over", "return"}

HELP_TEXT = f"""\
tracer-sink {VERSION}
Детерминированный оркестратор трейса EDT Debug Tracer.

ИСПОЛЬЗОВАНИЕ:
  tracer-sink [OPTIONS] [JSON]
  echo '{{...}}' | tracer-sink [OPTIONS]

ОБЯЗАТЕЛЬНЫЕ ПОЛЯ JSON:
  project       string   Имя проекта в EDT workspace

ОПЦИОНАЛЬНЫЕ ПОЛЯ JSON:
  mainClass     string   Точка входа (по умолчанию: "")
  args          string   Аргументы запуска (по умолчанию: "")
  maxSteps      int>=0   Лимит шагов, 0=безлимит (по умолчанию: 0)
  stepType      string   into|over|return (по умолчанию: "into")
  saveJson      bool     Сохранить JSON на диск (по умолчанию: true)
  timeoutMs     int>0    Таймаут сессии в мс (по умолчанию: 30000)

EXIT CODES:
  0  SUCCESS        — трейс завершён
  1  NETWORK_ERROR  — HTTP-сервер недоступен
  2  CONTRACT_ERROR — невалидный входной JSON
  3  RUNTIME_ERROR  — ошибка выполнения сессии
  4  INTERNAL_ERROR — внутренняя ошибка CLI

OPTIONS:
  --host HOST    Адрес сервера (по умолчанию: localhost)
  --port PORT    Порт сервера (по умолчанию: 18080)
  --token TOKEN  Bearer-токен авторизации
  --timeout SEC  Таймаут HTTP-запроса в секундах (по умолчанию: 120)
  --help         Эта справка
  --version      Версия CLI
"""


def out(data: dict):
    """Единственная точка записи результата в stdout."""
    print(json.dumps(data, ensure_ascii=False))


def fail(code: int, message: str):
    out({"ok": False, "error": message, "exit_code": code})
    sys.exit(code)


def validate(req: dict):
    """Возвращает сообщение об ошибке или None."""
    project = req.get("project", "")
    if not isinstance(project, str) or not project.strip():
        return "\u043f\u043e\u043b\u0435 'project' \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0438 \u043d\u0435 \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u043f\u0443\u0441\u0442\u044b\u043c"

    max_steps = req.get("maxSteps", 0)
    if not isinstance(max_steps, int) or isinstance(max_steps, bool) or max_steps < 0:
        return f"\u043f\u043e\u043b\u0435 'maxSteps' \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u0446\u0435\u043b\u044b\u043c \u0447\u0438\u0441\u043b\u043e\u043c >= 0, \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u043e: {max_steps!r}"

    step_type = req.get("stepType", "into")
    if step_type not in VALID_STEP_TYPES:
        return f"\u043f\u043e\u043b\u0435 'stepType' \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u043e\u0434\u043d\u0438\u043c \u0438\u0437 {sorted(VALID_STEP_TYPES)}, \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u043e: {step_type!r}"

    timeout_ms = req.get("timeoutMs", 30000)
    if not isinstance(timeout_ms, int) or isinstance(timeout_ms, bool) or timeout_ms <= 0:
        return f"\u043f\u043e\u043b\u0435 'timeoutMs' \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u0446\u0435\u043b\u044b\u043c \u0447\u0438\u0441\u043b\u043e\u043c > 0, \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u043e: {timeout_ms!r}"

    return None


def run(raw_json: str, host: str, port: int, token, http_timeout: int):
    # --- шаг 5: парсинг JSON ---
    try:
        req = json.loads(raw_json)
    except json.JSONDecodeError as e:
        fail(EXIT_CONTRACT_ERROR, f"\u043d\u0435\u0432\u0430\u043b\u0438\u0434\u043d\u044b\u0439 JSON: {e}")

    if not isinstance(req, dict):
        fail(EXIT_CONTRACT_ERROR, "\u0432\u0445\u043e\u0434\u043d\u043e\u0439 JSON \u0434\u043e\u043b\u0436\u0435\u043d \u0431\u044b\u0442\u044c \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u043c {}")

    # --- шаг 6: валидация контракта ---
    err = validate(req)
    if err:
        fail(EXIT_CONTRACT_ERROR, err)

    # --- шаг 7: HTTP POST /sink/run ---
    url = f"http://{host}:{port}/sink/run"
    body = json.dumps(req, ensure_ascii=False).encode("utf-8")
    http_req = urllib.request.Request(
        url, data=body, method="POST",
        headers={"Content-Type": "application/json"},
    )
    if token:
        http_req.add_header("Authorization", f"Bearer {token}")

    try:
        with urllib.request.urlopen(http_req, timeout=http_timeout) as resp:
            resp_body = resp.read().decode("utf-8")
    except urllib.error.URLError as e:
        fail(EXIT_NETWORK_ERROR, f"\u0441\u0435\u0440\u0432\u0435\u0440 \u043d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d ({host}:{port}): {e.reason}")
    except TimeoutError:
        fail(EXIT_NETWORK_ERROR, f"\u0442\u0430\u0439\u043c\u0430\u0443\u0442 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044f \u0441 {host}:{port}")
    except Exception as e:
        fail(EXIT_NETWORK_ERROR, f"\u043e\u0448\u0438\u0431\u043a\u0430 \u0441\u0435\u0442\u0438: {e}")

    # --- шаг 8: разбор ответа ---
    try:
        result = json.loads(resp_body)
    except json.JSONDecodeError:
        fail(EXIT_INTERNAL_ERROR, f"\u0441\u0435\u0440\u0432\u0435\u0440 \u0432\u0435\u0440\u043d\u0443\u043b \u043d\u0435\u0432\u0430\u043b\u0438\u0434\u043d\u044b\u0439 JSON: {resp_body[:200]}")

    if result.get("ok"):
        result["exit_code"] = EXIT_SUCCESS
        out(result)
        sys.exit(EXIT_SUCCESS)
    else:
        result["exit_code"] = EXIT_RUNTIME_ERROR
        out(result)
        sys.exit(EXIT_RUNTIME_ERROR)


def main():
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("json_input", nargs="?", default=None)
    parser.add_argument("--host",    default="localhost")
    parser.add_argument("--port",    type=int, default=18080)
    parser.add_argument("--token",   default=None)
    parser.add_argument("--timeout", type=int, default=120, dest="http_timeout")
    parser.add_argument("--help",    action="store_true")
    parser.add_argument("--version", action="store_true")

    try:
        args = parser.parse_args()
    except SystemExit:
        fail(EXIT_CONTRACT_ERROR, "\u043e\u0448\u0438\u0431\u043a\u0430 \u0440\u0430\u0437\u0431\u043e\u0440\u0430 \u0430\u0440\u0433\u0443\u043c\u0435\u043d\u0442\u043e\u0432, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 --help")

    if args.help:
        print(HELP_TEXT, end="")
        sys.exit(EXIT_SUCCESS)

    if args.version:
        print(f"tracer-sink {VERSION}")
        sys.exit(EXIT_SUCCESS)

    # --- шаг 4: чтение JSON ---
    if args.json_input is not None:
        raw = args.json_input
    elif not sys.stdin.isatty():
        raw = sys.stdin.read()
    else:
        print(HELP_TEXT, end="", file=sys.stderr)
        fail(EXIT_CONTRACT_ERROR, "\u043d\u0435 \u043f\u0435\u0440\u0435\u0434\u0430\u043d \u0432\u0445\u043e\u0434\u043d\u043e\u0439 JSON (\u0430\u0440\u0433\u0443\u043c\u0435\u043d\u0442 \u0438\u043b\u0438 stdin)")

    raw = raw.strip()
    if not raw:
        fail(EXIT_CONTRACT_ERROR, "\u0432\u0445\u043e\u0434\u043d\u043e\u0439 JSON \u043f\u0443\u0441\u0442\u043e\u0439")

    # --- шаги 5-9 ---
    try:
        run(raw, args.host, args.port, args.token, args.http_timeout)
    except SystemExit:
        raise
    except Exception as e:
        fail(EXIT_INTERNAL_ERROR, f"\u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u044f\u044f \u043e\u0448\u0438\u0431\u043a\u0430: {type(e).__name__}: {e}")


if __name__ == "__main__":
    main()
