#!/usr/bin/env python3
"""
tracer-sink — детерминированный оркестратор конкретных сценариев
использования EDT Debug Tracer.

Субкоманды:
  trace-session        Полный цикл трейса (POST /sink/run)
                       Контракт: docs/cli-sink/SRS-trace-session.md
  breakpoint-metrics   Срез состояния в точке останова (POST /sink/breakpoint)
                       Контракт: docs/cli-sink/SRS-breakpoint-metrics.md

Правило: бизнес-логика трейса и сбора метрик — в Java-компонентах плагина.
CLI — только валидация контракта, один HTTP-вызов, маппинг ответа в exit code.
"""
import argparse
import json
import sys
import urllib.error
import urllib.request

VERSION = "2.0.0"

EXIT_SUCCESS        = 0
EXIT_NETWORK_ERROR  = 1
EXIT_CONTRACT_ERROR = 2
EXIT_RUNTIME_ERROR  = 3
EXIT_INTERNAL_ERROR = 4

VALID_STEP_TYPES = {"into", "over", "return"}

# ---------------------------------------------------------------------------
# Shared I/O
# ---------------------------------------------------------------------------

def out(data: dict):
    """Единственная точка записи результата в stdout."""
    print(json.dumps(data, ensure_ascii=False))


def fail(code: int, message: str):
    out({"ok": False, "error": message, "exit_code": code})
    sys.exit(code)


def read_raw_json(json_arg):
    """Читает сырой JSON из аргумента или stdin."""
    if json_arg is not None:
        raw = json_arg
    elif not sys.stdin.isatty():
        raw = sys.stdin.read()
    else:
        return None
    return raw.strip() or None


def parse_json(raw: str) -> dict:
    """Парсит JSON; при ошибке вызывает fail(2)."""
    try:
        obj = json.loads(raw)
    except json.JSONDecodeError as e:
        fail(EXIT_CONTRACT_ERROR, f"невалидный JSON: {e}")
    if not isinstance(obj, dict):
        fail(EXIT_CONTRACT_ERROR, "входной JSON должен быть объектом {}")
    return obj


def http_post(host: str, port: int, path: str, body: dict, token, timeout: int) -> dict:
    """POST запрос; при ошибке сети вызывает fail(1)."""
    url = f"http://{host}:{port}{path}"
    data = json.dumps(body, ensure_ascii=False).encode("utf-8")
    req = urllib.request.Request(
        url, data=data, method="POST",
        headers={"Content-Type": "application/json"},
    )
    if token:
        req.add_header("Authorization", f"Bearer {token}")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            resp_body = resp.read().decode("utf-8")
    except urllib.error.URLError as e:
        fail(EXIT_NETWORK_ERROR, f"сервер недоступен ({host}:{port}): {e.reason}")
    except TimeoutError:
        fail(EXIT_NETWORK_ERROR, f"таймаут соединения с {host}:{port}")
    except Exception as e:
        fail(EXIT_NETWORK_ERROR, f"ошибка сети: {e}")
    try:
        return json.loads(resp_body)
    except json.JSONDecodeError:
        fail(EXIT_INTERNAL_ERROR, f"сервер вернул невалидный JSON: {resp_body[:200]}")


def map_result(result: dict):
    """Добавляет exit_code в результат и завершает процесс."""
    if result.get("ok"):
        result["exit_code"] = EXIT_SUCCESS
        out(result)
        sys.exit(EXIT_SUCCESS)
    else:
        result["exit_code"] = EXIT_RUNTIME_ERROR
        out(result)
        sys.exit(EXIT_RUNTIME_ERROR)


# ---------------------------------------------------------------------------
# Subcommand: trace-session
# ---------------------------------------------------------------------------

HELP_TRACE_SESSION = f"""\
tracer-sink trace-session {VERSION}
Детерминированный оркестратор полного цикла трейса EDT Debug Tracer.
Контракт: docs/cli-sink/SRS-trace-session.md

ИСПОЛЬЗОВАНИЕ:
  tracer-sink trace-session [OPTIONS] [JSON]
  echo '{{...}}' | tracer-sink trace-session [OPTIONS]

ОБЯЗАТЕЛЬНЫЕ ПОЛЯ JSON:
  project       string   Имя проекта в EDT workspace

ОПЦИОНАЛЬНЫЕ ПОЛЯ JSON:
  mainClass     string   Точка входа (по умолчанию: "")
  args          string   Аргументы запуска (по умолчанию: "")
  maxSteps      int>=0   Лимит шагов, 0=безлимит (по умолчанию: 0)
  stepType      string   into|over|return (по умолчанию: "into")
  saveJson      bool     Сохранить JSON на диск (по умолчанию: true)
  timeoutMs     int>0    Таймаут сессии в мс (по умолчанию: 30000)

EXIT CODES:
  0  SUCCESS        — трейс завершён
  1  NETWORK_ERROR  — HTTP-сервер недоступен
  2  CONTRACT_ERROR — невалидный входной JSON
  3  RUNTIME_ERROR  — ошибка выполнения сессии
  4  INTERNAL_ERROR — внутренняя ошибка CLI

OPTIONS:
  --host HOST    Адрес сервера (по умолчанию: localhost)
  --port PORT    Порт сервера (по умолчанию: 18080)
  --token TOKEN  Bearer-токен авторизации
  --timeout SEC  Таймаут HTTP-запроса в секундах (по умолчанию: 120)
  --help         Эта справка
"""


def validate_trace_session(req: dict):
    project = req.get("project", "")
    if not isinstance(project, str) or not project.strip():
        return "поле 'project' обязательно и не должно быть пустым"

    max_steps = req.get("maxSteps", 0)
    if not isinstance(max_steps, int) or isinstance(max_steps, bool) or max_steps < 0:
        return f"поле 'maxSteps' должно быть целым числом >= 0, получено: {max_steps!r}"

    step_type = req.get("stepType", "into")
    if step_type not in VALID_STEP_TYPES:
        return f"поле 'stepType' должно быть одним из {sorted(VALID_STEP_TYPES)}, получено: {step_type!r}"

    timeout_ms = req.get("timeoutMs", 30000)
    if not isinstance(timeout_ms, int) or isinstance(timeout_ms, bool) or timeout_ms <= 0:
        return f"поле 'timeoutMs' должно быть целым числом > 0, получено: {timeout_ms!r}"

    return None


def cmd_trace_session(argv):
    p = argparse.ArgumentParser(prog="tracer-sink trace-session", add_help=False)
    p.add_argument("json_input", nargs="?", default=None)
    p.add_argument("--host",    default="localhost")
    p.add_argument("--port",    type=int, default=18080)
    p.add_argument("--token",   default=None)
    p.add_argument("--timeout", type=int, default=120, dest="http_timeout")
    p.add_argument("--help",    action="store_true")

    try:
        args = p.parse_args(argv)
    except SystemExit:
        fail(EXIT_CONTRACT_ERROR, "ошибка разбора аргументов, используйте --help")

    if args.help:
        print(HELP_TRACE_SESSION, end="")
        sys.exit(EXIT_SUCCESS)

    raw = read_raw_json(args.json_input)
    if not raw:
        print(HELP_TRACE_SESSION, end="", file=sys.stderr)
        fail(EXIT_CONTRACT_ERROR, "не передан входной JSON (аргумент или stdin)")

    req = parse_json(raw)

    err = validate_trace_session(req)
    if err:
        fail(EXIT_CONTRACT_ERROR, err)

    result = http_post(args.host, args.port, "/sink/run", req, args.token, args.http_timeout)
    map_result(result)


# ---------------------------------------------------------------------------
# Subcommand: breakpoint-metrics
# ---------------------------------------------------------------------------

HELP_BREAKPOINT_METRICS = f"""\
tracer-sink breakpoint-metrics {VERSION}
Детерминированный оркестратор сбора показателей состояния программы
в заданной точке останова EDT Debug Tracer.
Контракт: docs/cli-sink/SRS-breakpoint-metrics.md

ИСПОЛЬЗОВАНИЕ:
  tracer-sink breakpoint-metrics [OPTIONS] [JSON]
  echo '{{...}}' | tracer-sink breakpoint-metrics [OPTIONS]

ОБЯЗАТЕЛЬНЫЕ ПОЛЯ JSON:
  project       string   Имя проекта в EDT workspace
  file          string   Путь к файлу относительно корня проекта
  line          int>0    Номер строки точки останова

ОПЦИОНАЛЬНЫЕ ПОЛЯ JSON:
  variables     string[] Список имён переменных (пусто = все доступные)
  mainClass     string   Точка входа (по умолчанию: "")
  args          string   Аргументы запуска (по умолчанию: "")
  timeoutMs     int>0    Таймаут ожидания точки останова в мс (по умолчанию: 30000)

EXIT CODES:
  0  SUCCESS        — точка достигнута, срез собран
  1  NETWORK_ERROR  — HTTP-сервер недоступен
  2  CONTRACT_ERROR — невалидный входной JSON
  3  RUNTIME_ERROR  — точка не достигнута за timeoutMs или ошибка запуска
  4  INTERNAL_ERROR — внутренняя ошибка CLI

OPTIONS:
  --host HOST    Адрес сервера (по умолчанию: localhost)
  --port PORT    Порт сервера (по умолчанию: 18080)
  --token TOKEN  Bearer-токен авторизации
  --timeout SEC  Таймаут HTTP-запроса в секундах (по умолчанию: 120)
  --help         Эта справка
"""


def validate_breakpoint_metrics(req: dict):
    project = req.get("project", "")
    if not isinstance(project, str) or not project.strip():
        return "поле 'project' обязательно и не должно быть пустым"

    file_ = req.get("file", "")
    if not isinstance(file_, str) or not file_.strip():
        return "поле 'file' обязательно и не должно быть пустым"

    line = req.get("line")
    if line is None:
        return "поле 'line' обязательно"
    if not isinstance(line, int) or isinstance(line, bool) or line <= 0:
        return f"поле 'line' должно быть целым числом > 0, получено: {line!r}"

    variables = req.get("variables", [])
    if not isinstance(variables, list):
        return f"поле 'variables' должно быть массивом строк, получено: {type(variables).__name__}"
    for i, v in enumerate(variables):
        if not isinstance(v, str):
            return f"поле 'variables[{i}]' должно быть строкой, получено: {v!r}"

    timeout_ms = req.get("timeoutMs", 30000)
    if not isinstance(timeout_ms, int) or isinstance(timeout_ms, bool) or timeout_ms <= 0:
        return f"поле 'timeoutMs' должно быть целым числом > 0, получено: {timeout_ms!r}"

    return None


def cmd_breakpoint_metrics(argv):
    p = argparse.ArgumentParser(prog="tracer-sink breakpoint-metrics", add_help=False)
    p.add_argument("json_input", nargs="?", default=None)
    p.add_argument("--host",    default="localhost")
    p.add_argument("--port",    type=int, default=18080)
    p.add_argument("--token",   default=None)
    p.add_argument("--timeout", type=int, default=120, dest="http_timeout")
    p.add_argument("--help",    action="store_true")

    try:
        args = p.parse_args(argv)
    except SystemExit:
        fail(EXIT_CONTRACT_ERROR, "ошибка разбора аргументов, используйте --help")

    if args.help:
        print(HELP_BREAKPOINT_METRICS, end="")
        sys.exit(EXIT_SUCCESS)

    raw = read_raw_json(args.json_input)
    if not raw:
        print(HELP_BREAKPOINT_METRICS, end="", file=sys.stderr)
        fail(EXIT_CONTRACT_ERROR, "не передан входной JSON (аргумент или stdin)")

    req = parse_json(raw)

    err = validate_breakpoint_metrics(req)
    if err:
        fail(EXIT_CONTRACT_ERROR, err)

    result = http_post(args.host, args.port, "/sink/breakpoint", req, args.token, args.http_timeout)
    map_result(result)


# ---------------------------------------------------------------------------
# Top-level dispatcher
# ---------------------------------------------------------------------------

HELP_TOP = f"""\
tracer-sink {VERSION}
Детерминированный оркестратор конкретных сценариев использования EDT Debug Tracer.

ИСПОЛЬЗОВАНИЕ:
  tracer-sink <СУБКОМАНДА> [OPTIONS] [JSON]

СУБКОМАНДЫ:
  trace-session        Полный цикл трейса (POST /sink/run)
  breakpoint-metrics   Срез состояния в точке останова (POST /sink/breakpoint)

ОПЦИИ (верхний уровень):
  --version      Версия CLI
  --help         Эта справка

Справка по субкоманде:
  tracer-sink trace-session --help
  tracer-sink breakpoint-metrics --help
"""

SUBCOMMANDS = {
    "trace-session":      cmd_trace_session,
    "breakpoint-metrics": cmd_breakpoint_metrics,
}


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("--help", "-h"):
        print(HELP_TOP, end="")
        sys.exit(EXIT_SUCCESS)

    if args[0] in ("--version", "-v"):
        print(f"tracer-sink {VERSION}")
        sys.exit(EXIT_SUCCESS)

    subcmd = args[0]
    if subcmd not in SUBCOMMANDS:
        fail(EXIT_CONTRACT_ERROR,
             f"неизвестная субкоманда: {subcmd!r}. "
             f"Доступные: {', '.join(sorted(SUBCOMMANDS))}. "
             f"Используйте --help.")

    try:
        SUBCOMMANDS[subcmd](args[1:])
    except SystemExit:
        raise
    except Exception as e:
        fail(EXIT_INTERNAL_ERROR, f"внутренняя ошибка: {type(e).__name__}: {e}")


if __name__ == "__main__":
    main()
